/* ===== 记录页样式 ===== */
.page-record {
  padding: 32rpx 0 120rpx;
}

/* 上传区域 */
.record-upload-area {
  margin: 0 32rpx;
  background: var(--gray-50);
  border: 4rpx dashed var(--gray-200);
  border-radius: var(--radius-lg);
  padding: 120rpx 40rpx;
  text-align: center;
  transition: .2s;
}

.record-upload-area:active {
  border-color: var(--green);
  background: var(--green-bg);
}

.upload-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  display: block;
}

.upload-main-text {
  font-size: 32rpx;
  color: var(--gray-600);
  font-weight: 500;
}

.upload-sub-text {
  font-size: 26rpx;
  color: var(--gray-400);
  margin-top: 12rpx;
}

/* 拍照/相册按钮 */
.record-buttons {
  display: flex;
  gap: 24rpx;
  padding: 0 32rpx;
  margin: 24rpx 0;
}

.record-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 28rpx;
  border-radius: var(--radius);
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.record-btn.primary {
  background: var(--green);
  color: #fff;
}

.record-btn.primary:active {
  background: var(--green-dark);
}

.record-btn.primary::after {
  border: none;
}

.record-btn.secondary {
  background: var(--gray-100);
  color: var(--gray-700);
}

.record-btn.secondary:active {
  background: var(--gray-200);
}

.record-btn.secondary::after {
  border: none;
}

/* 手动录入入口 */
.record-manual-link {
  text-align: center;
  padding: 16rpx 32rpx 40rpx;
  font-size: 28rpx;
  color: var(--gray-400);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.record-manual-link:active {
  color: var(--green);
}

/* 编辑表单 */
.edit-form {
  margin: 0;
  background: #fff;
  overflow: hidden;
  display: none;
}

.edit-form.show {
  display: block;
}

/* 图片区（点击可重选） */
.edit-img {
  width: 100%;
  height: 400rpx;
  background: var(--gray-100);
  position: relative;
  overflow: hidden;
}

.edit-image {
  width: 100%;
  height: 100%;
}

.edit-img-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 64rpx;
  background: rgba(0,0,0,.35);
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-img-tip {
  font-size: 24rpx;
  color: rgba(255,255,255,.85);
}

.result-emoji {
  font-size: 128rpx;
}

/* 表单区域 */
.edit-body {
  padding: 32rpx 24rpx;
}

.form-field {
  margin-bottom: 28rpx;
  width: 100%;
}

.field-label {
  font-size: 26rpx;
  color: var(--gray-500);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.field-input {
  display: block;
  width: 100%;
  padding: 32rpx 28rpx;
  border: 3rpx solid var(--gray-200);
  border-radius: 16rpx;
  font-size: 30rpx;
  line-height: 1.5;
  color: var(--gray-700);
  outline: none;
  box-sizing: border-box;
  background: #fff;
  height: auto;
  min-height: 96rpx;
}

.name-input {
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.4;
  min-height: 104rpx;
  flex: 1;
}

/* 名称行（输入框 + 收藏按钮） */
.name-row {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
}

.name-fav {
  width: 104rpx;
  min-height: 104rpx;
  border-radius: 16rpx;
  border: 3rpx solid var(--gray-200);
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
}

.name-fav:active {
  background: var(--gray-50);
  transform: scale(.95);
}

/* 位置信息（点击选点） */
.field-location {
  padding: 24rpx 24rpx;
  background: var(--green-bg);
  border: 3rpx dashed var(--green-light);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: var(--green);
  line-height: 1.5;
  text-align: center;
}

.field-location:active {
  opacity: .7;
}

.field-location.empty {
  color: var(--green);
  font-weight: 500;
}

.field-input:focus {
  border-color: var(--green);
  box-shadow: 0 0 0 6rpx rgba(16,185,129,.1);
}

/* 多行备注 */
.field-textarea {
  display: block;
  width: 100%;
  padding: 32rpx 28rpx;
  border: 3rpx solid var(--gray-200);
  border-radius: 16rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: var(--gray-700);
  outline: none;
  box-sizing: border-box;
  background: #fff;
  min-height: 160rpx;
  height: auto;
}

.field-textarea:focus {
  border-color: var(--green);
  box-shadow: 0 0 0 6rpx rgba(16,185,129,.1);
}

/* 餐次选择 */
.meal-select {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.meal-opt {
  padding: 8rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  border: 3rpx solid var(--gray-200);
  color: var(--gray-400);
  transition: .15s;
}

.meal-opt.active {
  border-color: var(--green);
  background: var(--green-bg);
  color: var(--green);
  font-weight: 600;
}

.meal-opt:active {
  transform: scale(.95);
}

/* 好吃程度选择 */
.taste-selector {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.taste-opt {
  flex: 1;
  text-align: center;
  padding: 20rpx 12rpx;
  border-radius: 20rpx;
  border: 3rpx solid var(--gray-200);
  font-size: 26rpx;
  color: var(--gray-500);
  transition: .15s;
  min-width: 120rpx;
}

.taste-opt .taste-emoji {
  display: block;
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.taste-opt.active {
  background: var(--green-bg);
  border-color: var(--green);
  color: var(--green);
  font-weight: 600;
}

.taste-opt:active {
  transform: scale(.95);
}

/* 分类选择 */
/* 保存按钮 */
.edit-actions {
  display: flex;
  gap: 24rpx;
  padding: 0 24rpx 32rpx;
}

.edit-actions button {
  flex: 1;
  padding: 28rpx;
  border-radius: var(--radius);
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.edit-actions button::after {
  border: none;
}

.btn-cancel {
  background: var(--gray-100);
  color: var(--gray-600);
}

.btn-save {
  background: var(--green);
  color: #fff;
}

.btn-save:active {
  background: var(--green-dark);
}

/* ===== 手动录入弹窗 ===== */
.modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: rgba(0,0,0,.4);
  display: none;
  align-items: flex-end;
  justify-content: center;
}

.modal-overlay.open {
  display: flex;
}

.modal-sheet {
  background: #fff;
  width: 100%;
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: 0 0 48rpx;
  animation: slideUp .35s cubic-bezier(.4,0,.2,1);
  max-height: 85vh;
  overflow-y: auto;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-handle {
  width: 72rpx;
  height: 8rpx;
  background: var(--gray-300);
  border-radius: 4rpx;
  margin: 20rpx auto;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 40rpx 24rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--gray-900);
}

.modal-close {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--gray-100);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--gray-500);
  text-align: center;
  line-height: 64rpx;
}

.form-group {
  margin: 0 40rpx 32rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--gray-600);
  display: block;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  padding: 32rpx 28rpx;
  border: 3rpx solid var(--gray-200);
  border-radius: 20rpx;
  font-size: 30rpx;
  line-height: 1.5;
  outline: none;
  transition: .2s;
  background: #fff;
  box-sizing: border-box;
  min-height: 96rpx;
}

.form-input:focus {
  border-color: var(--green);
  box-shadow: 0 0 0 6rpx rgba(16,185,129,.1);
}

.form-textarea {
  width: 100%;
  padding: 32rpx 28rpx;
  border: 3rpx solid var(--gray-200);
  border-radius: 20rpx;
  font-size: 30rpx;
  line-height: 1.6;
  outline: none;
  background: #fff;
  box-sizing: border-box;
  min-height: 160rpx;
  height: auto;
}

.form-textarea:focus {
  border-color: var(--green);
  box-shadow: 0 0 0 6rpx rgba(16,185,129,.1);
}

.form-submit {
  margin: 8rpx 40rpx 0;
  padding: 28rpx;
  border: none;
  border-radius: var(--radius);
  background: var(--green);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  width: calc(100% - 80rpx);
}

.form-submit:active {
  background: var(--green-dark);
}

.form-submit::after {
  border: none;
}
