/* ===== 收藏页样式 ===== */
.page-favorites {
  min-height: 100vh;
  background: var(--gray-50);
  padding-bottom: 40rpx;
}

.fav-header {
  padding: 24rpx 40rpx;
  background: #fff;
  border-bottom: 2rpx solid var(--gray-100);
}

.fav-count {
  font-size: 26rpx;
  color: var(--gray-400);
}

/* 收藏项 */
.fav-item {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  margin: 0 32rpx 8rpx;
  border-radius: var(--radius);
  background: #fff;
  box-shadow: var(--shadow);
  position: relative;
  align-items: center;
}

.fav-item:active {
  opacity: .8;
}

.food-img {
  width: 112rpx;
  height: 112rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.food-img-text {
  font-size: 56rpx;
}

.food-img-real {
  width: 100%;
  height: 100%;
}

.food-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.food-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--gray-800);
}

.food-meta {
  font-size: 26rpx;
  color: var(--gray-400);
  margin-top: 4rpx;
}

.food-taste {
  text-align: right;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  margin-right: 16rpx;
}

.food-taste-emoji {
  font-size: 44rpx;
  line-height: 1;
}

.food-taste-label {
  font-size: 20rpx;
  color: var(--gray-400);
}

.fav-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  font-size: 28rpx;
}

/* 空状态 */
.empty-icon {
  font-size: 128rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--gray-400);
  line-height: 1.6;
  white-space: pre-line;
}

.empty-btn {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 32rpx;
  padding: 20rpx 48rpx;
  border-radius: 48rpx;
  background: var(--green);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.empty-btn::after {
  border: none;
}
