/* ===== 首页样式 ===== */
.page-home {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  background: var(--gray-50);
}

/* 固定顶部区域 */
.home-header {
  flex-shrink: 0;
}

/* 可滑动记录区域 */
.home-scroll {
  flex: 1;
  overflow-y: scroll;
}

/* Hero区域 */
.hero-section {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  padding: 40rpx 40rpx 56rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.hero-section::after {
  content: '🍽️';
  position: absolute;
  right: -20rpx;
  top: -40rpx;
  font-size: 240rpx;
  opacity: .08;
}

.hero-greeting {
  font-size: 30rpx;
  opacity: .9;
  margin-bottom: 12rpx;
}

.hero-stats {
  display: flex;
  gap: 48rpx;
}

.hero-stat-num {
  font-size: 56rpx;
  font-weight: 800;
  line-height: 1.2;
}

.hero-stat-label {
  font-size: 24rpx;
  opacity: .75;
  margin-top: 4rpx;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255,255,255,.2);
  padding: 8rpx 24rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  margin-top: 24rpx;
}

/* 卡片标题 */
.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--gray-700);
  margin-bottom: 12rpx;
}

/* 好吃榜 */
.taste-dist-home {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
}

.taste-badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  font-size: 26rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.taste-badge.t1 { background: #fef3c7; color: #d97706; }
.taste-badge.t2 { background: #d1fae5; color: #059669; }
.taste-badge.t3 { background: #e0e7ff; color: #4f46e5; }
.taste-badge.t4 { background: #fee2e2; color: #dc2626; }

/* 区域标题 */
.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 40rpx 16rpx;
}

.section-title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--gray-800);
}

.section-more {
  font-size: 26rpx;
  color: var(--gray-400);
}

/* 记录项 */
.record-item {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  margin: 0 32rpx 4rpx;
  border-radius: var(--radius);
  transition: .15s;
}

.record-item:active {
  background: var(--gray-50);
}

.food-img {
  width: 112rpx;
  height: 112rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.food-img-text {
  font-size: 56rpx;
}

.food-img-real {
  width: 100%;
  height: 100%;
}

.food-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.food-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--gray-800);
}

.food-meta {
  font-size: 26rpx;
  color: var(--gray-400);
  margin-top: 4rpx;
}

.food-taste {
  text-align: right;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.food-taste-emoji {
  font-size: 44rpx;
  line-height: 1;
}

.food-taste-label {
  font-size: 20rpx;
  color: var(--gray-400);
}

/* 空状态 */
.empty-icon {
  font-size: 128rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--gray-400);
  line-height: 1.6;
  white-space: pre-line;
}

.empty-btn {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 32rpx;
  padding: 20rpx 48rpx;
  border-radius: 48rpx;
  background: var(--green);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.empty-btn::after {
  border: none;
}

/* 底部记录按钮 */
.home-fab {
  position: fixed;
  bottom: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 20;
  background: var(--green);
  color: #fff;
  padding: 20rpx 40rpx;
  border-radius: 56rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 28rpx rgba(16,185,129,.4);
  transition: .25s;
}

.home-fab:active {
  transform: translateX(-50%) scale(.95);
}

.home-fab-icon {
  font-size: 36rpx;
}
