/* ===== 个人页样式 ===== */
.page-profile {
  padding-bottom: 120rpx;
}

/* 用户信息头部 */
.profile-header {
  padding: 48rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
  background: #fff;
  margin-bottom: 24rpx;
}

.profile-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: var(--green-light);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.avatar-text {
  font-size: 64rpx;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.profile-info {
  flex: 1;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--gray-900);
}

.profile-desc {
  font-size: 26rpx;
  color: var(--gray-400);
  margin-top: 4rpx;
}

/* 菜单组 */
.menu-group {
  background: #fff;
  margin: 0 32rpx 24rpx;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid var(--gray-50);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--gray-50);
}

.menu-icon {
  font-size: 36rpx;
  width: 48rpx;
  text-align: center;
}

.menu-label {
  flex: 1;
  font-size: 28rpx;
  color: var(--gray-700);
}

.menu-badge {
  font-size: 26rpx;
  color: var(--gray-400);
}

.menu-arrow {
  color: var(--gray-300);
  font-size: 28rpx;
}

/* 版本号 */
.version-info {
  text-align: center;
  font-size: 24rpx;
  color: var(--gray-300);
  padding: 40rpx;
}
