/* ===== 照片墙样式 ===== */
.page-photos {
  min-height: 100vh;
  background: #fff;
  padding-bottom: 40rpx;
}

/* 头部 */
.photos-header {
  padding: 24rpx 40rpx;
  border-bottom: 2rpx solid var(--gray-100);
}

.photos-count {
  font-size: 26rpx;
  color: var(--gray-400);
}

/* 日期分组 */
.photo-group {
  padding: 0 24rpx;
}

.photo-date-divider {
  padding: 32rpx 16rpx 16rpx;
  font-size: 28rpx;
  color: var(--gray-500);
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.photo-date-divider::after {
  content: '';
  flex: 1;
  height: 2rpx;
  background: var(--gray-200);
}

/* 照片网格 */
.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 6rpx;
}

.photo-item {
  aspect-ratio: 1;
  overflow: hidden;
  border-radius: 8rpx;
}

.photo-item:active {
  opacity: .7;
}

.photo-bg {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-emoji {
  font-size: 56rpx;
}

.photo-real {
  width: 100%;
  height: 100%;
}

/* 空状态 */
.empty-icon {
  font-size: 128rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--gray-400);
  line-height: 1.6;
  white-space: pre-line;
}

.empty-btn {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 32rpx;
  padding: 20rpx 48rpx;
  border-radius: 48rpx;
  background: var(--green);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.empty-btn::after {
  border: none;
}
