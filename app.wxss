/* ===== 全局变量 ===== */
page {
  --green: #10b981;
  --green-dark: #059669;
  --green-light: #d1fae5;
  --green-bg: #ecfdf5;
  --orange: #f59e0b;
  --red: #ef4444;
  --blue: #3b82f6;
  --gray-50: #f9fafb;
  --gray-100: #f3f4f6;
  --gray-200: #e5e7eb;
  --gray-300: #d1d5db;
  --gray-400: #9ca3af;
  --gray-500: #6b7280;
  --gray-600: #4b5563;
  --gray-700: #374151;
  --gray-800: #1f2937;
  --gray-900: #111827;
  --shadow: 0 1px 3px 0 rgba(0,0,0,.06), 0 1px 2px 0 rgba(0,0,0,.04);
  --shadow-md: 0 4px 6px -1px rgba(0,0,0,.07), 0 2px 4px -1px rgba(0,0,0,.04);
  --shadow-lg: 0 10px 15px -3px rgba(0,0,0,.08), 0 4px 6px -2px rgba(0,0,0,.04);
  --radius: 12px;
  --radius-lg: 16px;
  --radius-xl: 20px;
  font-size: 28rpx;
  color: var(--gray-800);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

/* ===== 全局样式 ===== */
.container {
  background: var(--gray-50);
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: var(--radius);
  padding: 32rpx;
  box-shadow: var(--shadow);
  margin: 0 32rpx 24rpx;
}

/* ===== 导航占位 ===== */
.nav-placeholder {
  height: var(--status-bar-height, 88rpx);
  background: #fff;
}

/* ===== 空状态 ===== */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-state .icon {
  font-size: 128rpx;
  margin-bottom: 24rpx;
}

.empty-state .text {
  font-size: 30rpx;
  color: var(--gray-400);
  line-height: 1.6;
}

.empty-state .btn {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 32rpx;
  padding: 20rpx 48rpx;
  border-radius: 48rpx;
  background: var(--green);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

/* ===== Toast ===== */
.toast-container {
  position: fixed;
  top: 160rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 9999;
  pointer-events: none;
}

.toast {
  background: var(--gray-900);
  color: #fff;
  padding: 20rpx 40rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  white-space: nowrap;
  box-shadow: var(--shadow-lg);
}
