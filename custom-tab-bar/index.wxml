<view class="tab-bar">
  <view
    class="tab-item {{selected === 0 ? 'active' : ''}}"
    data-index="0"
    bindtap="switchTab"
  >
    <text class="tab-text">首页</text>
  </view>
  <view
    class="tab-item {{selected === 1 ? 'active' : ''}}"
    data-index="1"
    bindtap="switchTab"
  >
    <text class="tab-text">记录</text>
  </view>
  <view
    class="tab-item {{selected === 2 ? 'active' : ''}}"
    data-index="2"
    bindtap="switchTab"
  >
    <text class="tab-text">我的</text>
  </view>
</view>
